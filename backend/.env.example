# Server Port
PORT=5001

# Nodemailer SMTP Configuration
# Set these to send real emails, otherwise the app falls back to dev logging
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_TO=your_email@gmail.com
SMTP_FROM=your_email@gmail.com
CONTACT_TO_EMAIL=your_email@gmail.com

# GitHub Personal Access Token (Optional)
# Set this to increase the GitHub API rate limit for fetching your profile
GITHUB_TOKEN=
