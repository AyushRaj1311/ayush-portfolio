{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "buildCommand": "npm --prefix frontend install && npm --prefix frontend run build",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
